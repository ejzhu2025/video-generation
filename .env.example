# Anthropic API — Claude storyboard agent + photo analysis
# Get at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# fal.ai — video generation
# Sign up at https://fal.ai for free credits
FAL_API_KEY=...
FAL_T2V_MODEL=fal-ai/wan/v2.1/t2v-14b
FAL_I2V_MODEL=fal-ai/wan/v2.2-a14b/image-to-video

# Video backend: "fal" | "luma" | "mock"
# Set to "mock" to test the full UI flow without any API keys
VIDEO_BACKEND=fal

# LumaAI (optional premium alternative)
# LUMA_API_KEY=luma-...

# Public URL of this server (required for I2V on deployed environments)
# fal.ai needs to fetch your uploaded images from a public URL
# Example: https://your-app.railway.app
# SERVER_URL=https://your-deployment.com
